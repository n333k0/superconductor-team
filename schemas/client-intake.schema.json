{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agency-discovery-os.local/schemas/client-intake.schema.json",
  "title": "Agency Discovery OS Client Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "client_slug",
    "organization",
    "engagement_objective",
    "audiences",
    "constraints",
    "source_refs",
    "open_questions"
  ],
  "properties": {
    "client_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "organization": {
      "type": "string",
      "minLength": 1
    },
    "engagement_objective": {
      "type": "string",
      "minLength": 10
    },
    "audiences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "question",
          "why_it_matters"
        ],
        "properties": {
          "priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "question": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          }
        }
      }
    }
  }
}
