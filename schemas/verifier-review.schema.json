{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agency-discovery-os.local/schemas/verifier-review.schema.json",
  "title": "Agency Discovery OS Verifier Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "client_slug",
    "demo_readiness",
    "internal_draft_readiness",
    "client_readiness",
    "final_decision",
    "findings"
  ],
  "properties": {
    "client_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "demo_readiness": {
      "type": "string",
      "description": "demo-ready means useful for internal demonstration or proof-of-system only; blocked means not safe to package or share until blockers are resolved.",
      "enum": [
        "demo-ready",
        "blocked"
      ]
    },
    "internal_draft_readiness": {
      "type": "string",
      "description": "internal-draft-ready means usable by the agency team but not client-facing yet; blocked means not safe to package or share until blockers are resolved.",
      "enum": [
        "internal-draft-ready",
        "blocked"
      ]
    },
    "client_readiness": {
      "type": "string",
      "description": "client-ready means safe to share externally with evidence, caveats, validation, and no unresolved blockers; blocked means not safe to package or share until blockers are resolved.",
      "enum": [
        "client-ready",
        "blocked"
      ]
    },
    "final_decision": {
      "type": "string",
      "description": "Highest safe readiness label: demo-ready, internal-draft-ready, client-ready, or blocked.",
      "enum": [
        "demo-ready",
        "internal-draft-ready",
        "client-ready",
        "blocked"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "file",
          "finding",
          "required_fix"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "material",
              "minor",
              "polish"
            ]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "finding": {
            "type": "string",
            "minLength": 10
          },
          "required_fix": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "validation_method": {
      "type": "string",
      "minLength": 1
    },
    "evidence_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "file",
          "evidence_ref",
          "result"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 10
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "caveat",
              "fail"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
